# ============================================
# NEXTAUTH CONFIGURATION
# ============================================
# NextAuth secret key for encryption (required)
# Generate a random string: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here

# Your app URL (change for production)
NEXTAUTH_URL=http://localhost:3000

# ============================================
# GITHUB OAUTH CONFIGURATION
# ============================================
# Get these from: https://github.com/settings/developers
# 1. Go to GitHub Settings → Developer settings → OAuth Apps → New OAuth App
# 2. Application name: Your app name
# 3. Homepage URL: http://localhost:3000
# 4. Authorization callback URL: http://localhost:3000/api/auth/callback
# 5. Copy Client ID and generate Client Secret

GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ============================================
# SUPABASE DATABASE CONFIGURATION
# ============================================
# Get this from: https://supabase.com/dashboard
# 1. Go to your project
# 2. Settings → Database
# 3. Scroll to "Connection string" section
# 4. Copy the "URI" format
# 5. Replace [YOUR-PASSWORD] with your database password

# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# ============================================
# SETUP INSTRUCTIONS:
# ============================================
# 1. Copy this file to .env.local
# 2. Fill in all the required values
# 3. DO NOT commit .env.local to git (it's in .gitignore)
# 4. For production, use environment variables in your hosting platform
